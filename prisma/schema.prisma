// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// NOTE: For Vercel deployment, this schema is not used.
// The app uses mock in-memory data instead.
// To use a real database, update this schema and follow the migration guide.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  role      Role       @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  favoriteTeams   FavoriteTeam[]
  favoritePlayers FavoritePlayer[]
  searchHistory   SearchHistory[]

  @@index([email])
  @@index([role])
}

model FavoriteTeam {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId    String
  teamName  String
  league    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, teamId])
  @@index([userId])
}

model FavoritePlayer {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playerId  String
  playerName String
  team      String
  position  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, playerId])
  @@index([userId])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  type      String   @default("team")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

enum Role {
  USER
  ADMIN
}
